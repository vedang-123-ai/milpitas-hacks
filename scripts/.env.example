# scripts/.env.example — TEMPLATE ONLY (committed). No real key in here.
#
# To enable AI content generation:
#   1. cd scripts && cp .env.example .env
#   2. paste your real key into .env  (that file is git-ignored, never committed)
#   3. npm install && npm run generate
#
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-paste-your-key-here

# Optional: override the default model (see scripts/generate-content.mjs)
# OPENAI_MODEL=gpt-4o-mini
